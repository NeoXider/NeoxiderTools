  m_Script: {fileID: 11500000, guid: 2f9eb3d1945ff1640a88058f7d4f2b42, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _moduleName: GridSystem Dice Merge Demo
  _purpose: Playable 5x5 dice merge puzzle sample built from GridSystem, Neo.Merge
    and Dice.
  _runtimeApi: Use Neo.Merge for generic groups, GridMergeResolver for FieldGenerator,
    DiceBoardService for dice placement.
  _sceneWorkflow: Drag the tray dice onto the board. Tap a pair in the tray to rotate
    it.
  _verification: Enter Play Mode, place dice, merge 3+ connected equal values, and
    reach game over.
  _showRuntimeOverlay: 0
